			vert(1.0, 1.0, 0.0),
			vert(0.0, 1.0, 0.0),
		],
		face_section(2),
	);
	geom.add_face_data(
		&[
			vert(2.0, 0.0, 0.0),
			vert(3.0, 0.0, 0.0),
			vert(2.0, 1.0, 0.0),
		],
		face_section(1),
	);

	// Keep only section 1 faces and move them to section 10
	let filtered = geom.flat_map_data(|face| {
		if face.section == 1 {
			vec![(face.vertices().to_vec(), face_section(10))]
		} else {
