	fn lerp_vec(self, other: Self, t: Self) -> Self {
		vec4(
			self.x.lerp(other.x, t.x),
			self.y.lerp(other.y, t.y),
			self.z.lerp(other.z, t.z),
			self.w.lerp(other.w, t.w),
		)
	}
}
