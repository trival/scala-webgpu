/// A tuple containing:
/// * Noise value in approximate range [-1.0, 1.0]
/// * Gradient vector (x,y,z partial derivatives)
pub fn rot_noise_3d(pos: Vec3, norm_rot: f32) -> (f32, Vec3) {
	tiling_rot_noise_3d(pos, Vec3::ZERO, norm_rot)
