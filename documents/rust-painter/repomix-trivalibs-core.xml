#[test]
fn from_iter() {
	let list = [1, 2, 3]
		.iter()
		.map(|n| item(n * 10))
		.collect::<NeighbourList<_>>();

	assert_eq!(list.first().unwrap().val, item_next(10, 20));
	assert_eq!(list.last().unwrap().val, item(30));

	assert_eq!(
		list.iter().map(|n| { n.val.number }).collect::<Vec<_>>(),
		[10, 20, 30]
	);

	assert_eq!(
		list.iter().map(|n| { n.val.next }).collect::<Vec<_>>(),
		[20, 30, 0]
	);
}

